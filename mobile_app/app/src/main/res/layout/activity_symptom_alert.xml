<?xml version="1.0" encoding="utf-8"?>
<!-- Symptom Alert – transparent overlay with warning card -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_dark"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:strokeWidth="2dp"
        app:strokeColor="@color/warning_alpha20"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <!-- Coffee emoji icon circle -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@color/warning_alpha10"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="☕"
                    android:textSize="36sp" />
            </FrameLayout>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/early_fatigue_title"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="@color/warning"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp"
                android:gravity="center" />

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/early_fatigue_body"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Countdown progress bar -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressCountdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="100"
                android:layout_marginBottom="8dp"
                app:trackColor="@color/accent_light"
                app:indicatorColor="@color/warning"
                app:trackCornerRadius="4dp" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Escalating to emergency in 10s"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginBottom="20dp"
                android:gravity="center" />

            <!-- I'm Awake button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImAwake"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:text="@string/btn_im_awake"
                app:backgroundTint="@color/warning"
                app:cornerRadius="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
