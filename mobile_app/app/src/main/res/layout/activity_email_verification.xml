<?xml version="1.0" encoding="utf-8"?>
<!-- Email Verification Screen -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:padding="16dp">

    <!-- Pre-verified state -->
    <LinearLayout
        android:id="@+id/layoutUnverified"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_icon_circle_primary"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mail_icon"
                    app:tint="@color/primary"
                    android:contentDescription="Email" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/check_email_title"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textColor="?attr/colorOnBackground"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/check_email_subtitle"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- OTP Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutline"
            app:cardBackgroundColor="?attr/colorSurface"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/enter_code_label"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center"
                    android:layout_marginBottom="20dp" />

                <!-- 6 OTP boxes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">

                    <EditText
                        android:id="@+id/etOtp1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium" />

                    <EditText
                        android:id="@+id/etOtp2"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium" />

                    <EditText
                        android:id="@+id/etOtp3"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium" />

                    <EditText
                        android:id="@+id/etOtp4"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium" />

                    <EditText
                        android:id="@+id/etOtp5"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium" />

                    <EditText
                        android:id="@+id/etOtp6"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:background="@drawable/bg_otp_box"
                        android:gravity="center"
                        android:inputType="number"
                        android:maxLength="1"
                        android:textSize="20sp"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Resend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvResendCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resend code in 60s"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResend"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/resend_code"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Verified state (hidden initially) -->
    <LinearLayout
        android:id="@+id/layoutVerified"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:background="@drawable/bg_icon_circle_primary"
            android:layout_marginBottom="16dp">
            <ImageView
                android:id="@+id/ivVerifiedIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/primary"
                android:contentDescription="Verified" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/verified_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="?attr/colorOnBackground"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/verified_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="8dp"
            android:gravity="center" />
    </LinearLayout>

</FrameLayout>
