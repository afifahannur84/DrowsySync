<?xml version="1.0" encoding="utf-8"?>
<!-- Microsleep Alert – full-screen red emergency -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/emergency"
    android:padding="32dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_alert_triangle"
        app:tint="@android:color/white"
        android:layout_marginBottom="32dp"
        android:contentDescription="Emergency alert"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/wake_up"
        android:textColor="@android:color/white"
        android:textSize="56sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.05"
        android:gravity="center"
        android:layout_marginBottom="40dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDismiss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:text="@string/btn_dismiss_alarm"
        android:textColor="@color/emergency"
        android:textSize="18sp"
        app:backgroundTint="@android:color/white"
        app:cornerRadius="8dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</LinearLayout>
