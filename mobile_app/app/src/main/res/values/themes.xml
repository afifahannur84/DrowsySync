<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base light theme -->
    <style name="Base.Theme.DrowsySyncApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_alpha20</item>
        <item name="colorOnPrimaryContainer">@color/on_background_light</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorSurface">@color/card_light</item>
        <item name="colorOnSurface">@color/on_background_light</item>
        <item name="colorSurfaceVariant">@color/input_bg_light</item>
        <item name="colorOnSurfaceVariant">@color/muted_fg_light</item>
        <item name="colorOutline">@color/border_light</item>
        <item name="colorError">@color/destructive</item>
        <item name="colorOnError">@color/on_destructive</item>
        <item name="android:windowBackground">@color/background_light</item>
    </style>

    <style name="Theme.DrowsySyncApp" parent="Base.Theme.DrowsySyncApp" />

    <!-- Transparent theme for SymptomAlertActivity overlay -->
    <style name="Theme.DrowsySyncApp.Transparent" parent="Theme.DrowsySyncApp">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@android:style/Animation</item>
    </style>
</resources>