# Auto-detect text files and normalize line endings
* text=auto

# Force LF for shell scripts and Python
*.py text eol=lf
*.sh text eol=lf
gradlew text eol=lf

# Force CRLF for Windows batch files
*.bat text eol=crlf

# Treat binary files as binary
*.dat binary
*.wav binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
